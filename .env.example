# App
NODE_ENV=development
NEXT_PUBLIC_APP_NAME="Hydrographic Poster Generator"

# API — base URL of the FastAPI backend, inlined into the frontend bundle
# at build time (must be reachable from the user's browser).
NEXT_PUBLIC_API_URL=http://localhost:8000

# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# Supabase
SUPABASE_URL=https://PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Deployment
PORT=8080

# Data / Import
HYDRORIVERS_SOURCE_DIR=./data/import/hydrorivers
BOUNDARY_SOURCE_DIR=./data/import/boundaries
